{
    "name": "greypanel/v2",
    "description": "Modern GreyPanel - CS:GO administration panel",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "vlucas/phpdotenv": "^5.6",
        "nikic/fast-route": "^1.3",
        "twig/twig": "^3.24",
        "symfony/cache": "^7.2",
        "symfony/http-foundation": "^7.2",
        "symfony/console": "^7.2",
        "symfony/filesystem": "^7.2",
        "symfony/rate-limiter": "^8.0",
        "monolog/monolog": "^3.10",
        "intervention/image": "^4.0",
        "league/flysystem-ftp": "^3.31",
        "xpaw/php-source-query-class": "^6.0",
        "league/commonmark": "^2.6",
        "symfony/mime": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/yaml": "^8.0",
        "symfony/validator": "^8.0",
        "twig/string-extra": "^3.24",
        "twig/intl-extra": "^3.24",
        "symfony/lock": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/property-access": "^8.0",
        "symfony/html-sanitizer": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/dependency-injection": "^8.0"
    },
    "require-dev": {
        "symfony/var-dumper": "^7.2",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "GreyPanel\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2048M",
        "phpstan-report": "vendor\\bin\\phpstan analyse --memory-limit=2048M --error-format=raw > phpstan_report.txt",
        "phpstan-clear-result-cache": "vendor/bin/phpstan clear-result-cache",
        "fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php"
    }
}
